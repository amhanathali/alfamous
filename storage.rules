rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Même idée que Firestore : lecture libre, écriture réservée aux utilisateurs
    // connectés (Auth) dans ce projet Firebase.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
