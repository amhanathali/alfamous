# =====================================================================
#  Alfamous — .gitignore
#  Objectif : ne JAMAIS publier de secrets, de données personnelles
#  ni de fichiers lourds/inutiles sur le dépôt public.
# =====================================================================

# ---------------------------------------------------------------------
# 🔴 SECRETS & CLÉS — ne jamais versionner
# ---------------------------------------------------------------------
# Clés de service Google Cloud / Firebase Admin (clé privée = accès total)
key.json
key.json.json
serviceAccountKey.json
**/serviceAccount*.json
**/*-adminsdk-*.json
**/*adminsdk*.json

# Secrets client OAuth Google
**/client_secret*.json
**/*.apps.googleusercontent.com.json

# Identifiants de connexion rapide (contiennent de vraies adresses e-mail)
**/quick-login.json
other/quick-login.json
public/jsZC/quick-login.json
functions/quick-login.json

# Secret local Apps Script (clé API Blogger) — garder secrets.example.gs versionné
Gscript/secrets.gs

# Variables d'environnement
.env
.env.*
!.env.example

# ---------------------------------------------------------------------
# 📦 Dépendances (régénérables via npm install)
# ---------------------------------------------------------------------
node_modules/
.npm
.yarn-integrity
bower_components

# ---------------------------------------------------------------------
# 🔥 Firebase (cache & artefacts locaux)
# ---------------------------------------------------------------------
.firebase/
firebase-debug.log*
firebase-debug.*.log*
*.local
.dataconnect/

# ---------------------------------------------------------------------
# 🗜️ Sauvegardes & archives lourdes (≈165 Mo) — hors dépôt
# ---------------------------------------------------------------------
*.rar
*.zip
*.7z
*.tgz

# ---------------------------------------------------------------------
# 📁 Dossier de travail local (archives, doublons, hors-ligne)
# ---------------------------------------------------------------------
other/

# ---------------------------------------------------------------------
# 🐍 Python (caches)
# ---------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------
# 🪵 Logs & couverture de tests
# ---------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage
.nyc_output
lib-cov
.eslintcache

# ---------------------------------------------------------------------
# ⚙️ Builds & artefacts
# ---------------------------------------------------------------------
dist/
build/
out/
.cache/
.grunt
build/Release

# ---------------------------------------------------------------------
# 💻 Système d'exploitation & IDE
# ---------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.pid
*.seed
*.pid.lock

# Fichiers Windows spécifiques au poste local
AutoRun_backup.reg
