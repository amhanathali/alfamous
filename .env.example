# =====================================================================
#  Alfamous — Modèle de variables d'environnement
#  Copiez ce fichier vers ".env" et remplissez vos valeurs.
#  ⚠️ Le fichier ".env" réel ne doit JAMAIS être committé (déjà ignoré).
# =====================================================================

# --- Google Cloud / Firebase Admin (Cloud Functions) ---
# Chemin LOCAL vers la clé de compte de service (NE PAS committer ce fichier .json)
GOOGLE_APPLICATION_CREDENTIALS=./functions/serviceAccount.json

# Bucket de stockage Firebase (ex. alfamous-amha.appspot.com)
FIREBASE_STORAGE_BUCKET=
GCLOUD_STORAGE_BUCKET=

# =====================================================================
#  Configuration SMTP & app — définie côté Firebase (PAS dans ce .env)
#  via la commande "firebase functions:config:set". Documenté ici pour mémoire :
#
#  firebase functions:config:set \
#    smtp.host="smtp.gmail.com" \
#    smtp.port="587" \
#    smtp.secure="false" \
#    smtp.user="VOTRE_COMPTE@gmail.com" \
#    smtp.pass="MOT_DE_PASSE_APPLICATION" \
#    email.from='"Alfamous" <VOTRE_COMPTE@gmail.com>' \
#    email.contact_to="boite.admin@example.com" \
#    app.public_url="https://votre-projet.web.app" \
#    newsletter.secret="UNE_CHAINE_ALEATOIRE_LONGUE"
# =====================================================================
