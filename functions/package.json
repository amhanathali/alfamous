    "firebase-admin": "^12.1.0",
    "firebase-functions": "^5.1.0",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
