{
  "hosting": {
    "public": "public",
    // Chemins relatifs à public/ : pas de déploiement de other/ ni des archives .rar.
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "*.gsheet",
      "*.rar",
      "other/**",
      "jsZC/quick-login.json"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Permissions-Policy",
            "value": "picture-in-picture=(self \"https://www.youtube.com\" \"https://www.youtube-nocookie.com\" \"https://youtu.be\" \"https://www.google.com\" \"https://docs.google.com\" \"https://drive.google.com\"), unload=*"
          }
        ]
      }
    ],
    "rewrites": [
      // Conserver l'accès direct à medias1.html
      { "source": "/medias1.html", "destination": "/medias1.html" },
      // Lien de désabonnement newsletter (Cloud Function europe-west1)
      { "source": "/newsletter-unsubscribe", "function": { "functionId": "newsletterUnsubscribe", "region": "europe-west1" } },

      // Fallback SPA pour le reste
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "storage": { "rules": "storage.rules" },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
